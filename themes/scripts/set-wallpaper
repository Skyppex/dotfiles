#!/usr/bin/env nu

if (which awww | is-empty) {
    print -e "awww not found"
    return
}

while (awww query | complete | get exit_code) != 0 {
    sleep 0.2sec
}

match (sys host).hostname {
    pod => {
        # all wallpapers
        let path = nu $"($env.CONFIG_PATH)/hypr/scripts/get-wallpaper" h
        awww img --outputs "eDP-1" --transition-duration=1 ($path | path expand)
        return
    }
    tower => {
        # horizontal wallpaper
        let path = nu $"($env.CONFIG_PATH)/hypr/scripts/get-wallpaper" h
        awww img --outputs "DP-1" --transition-duration=1 ($path | path expand)

        # vertical wallpaper
        let path = nu $"($env.CONFIG_PATH)/hypr/scripts/get-wallpaper" v
        awww img --outputs "DP-2" --transition-duration=1 ($path | path expand)
    }
}

