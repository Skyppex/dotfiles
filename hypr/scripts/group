#!/usr/bin/env nu

def main [direction: string] {
    if not ([left, right, up, down] | any {
        |it| $it == $direction
    }) {
        print -e $"invalid direction ($direction)"
        return
    }

    let active = hyprctl activewindow -j | from json
    let result = hyprctl dispatch $"hl.dsp.focus\({direction = '($direction)'})"

    if $result != ok {
        return
    }

    let adjacent = hyprctl activewindow -j | from json

    if ($adjacent.grouped | is-empty) {
        let result = hyprctl dispatch "hl.dsp.group.toggle()"

        if $result != ok {
            return
        }
    }

    let result = hyprctl dispatch $"hl.dsp.focus\({window = 'address:($active.address)'})"

    if $result != ok {
        return
    }

    let _ = hyprctl dispatch $"hl.dsp.window.move\({into_group = '($direction)'})"
}
